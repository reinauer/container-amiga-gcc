+  p0 = mult0 * s0 + 1;
+  p1 = mult0 * s1 + mult1 * s0;
+  p2 = mult0 * s2 + mult1 * s1 + mult2 * s0;
+  p3 = mult0 * s3 + mult1 * s2 + mult2 * s1 + mult3 * s0;
+
+  carry = p0 >> 16;
+  p0 &= 0xffffULL;
