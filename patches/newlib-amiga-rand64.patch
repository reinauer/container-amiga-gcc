+  carry = p2 >> 16;
+  p2 &= 0xffffULL;
+
+  p3 += carry;
+  p3 &= 0xffffULL;
+
+  *state = (unsigned long long) p0;
+  *state |= ((unsigned long long) p1) << 16;
+  *state |= ((unsigned long long) p2) << 32;
